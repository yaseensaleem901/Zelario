# Copy to .env.local and fill in only what you need.
# Most of the app works with defaults (API at http://localhost:5000).

# --- Core (if you run the backend locally) ---
# NEXT_PUBLIC_API_URL=http://localhost:5000

# --- Optional: Google sign-in on login/register ---
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Optional: Convex (NFT marketplace hide/report + admin tools) ---
# Run: npx convex dev   (creates .env.local with NEXT_PUBLIC_CONVEX_URL)
# NEXT_PUBLIC_CONVEX_URL=

# --- Optional: WalletConnect / mobile QR wallets (MetaMask works without this) ---
# Free project: https://cloud.reown.com — add http://localhost:3000 to allowlist
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
